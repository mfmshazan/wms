# Copy to .env and fill in your own values.

# Google Gemini API key (used by the AI assistant proxy).
GOOGLE_API_KEY=

# PostgreSQL connection string.
# Local:  postgresql://postgres:postgres@localhost:5432/wms?schema=public
# Neon:   postgresql://user:pass@ep-xxx.aws.neon.tech/wms?sslmode=require
DATABASE_URL=

# Secret used to sign JWT auth tokens (use a long random string).
JWT_SECRET=

# API server port (optional, defaults to 3001).
PORT=3001
